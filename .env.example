# ============================================
# KithTrust Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Deployer Account (generate with: stellar keys generate --fund deployer)
STELLAR_ACCOUNT=deployer

# Contract Addresses (populated after deployment)
GOVERNANCE_CONTRACT_ID=
VAULT_CONTRACT_ID=

# Frontend Environment Variables
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_GOVERNANCE_CONTRACT_ID=
NEXT_PUBLIC_VAULT_CONTRACT_ID=
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet
